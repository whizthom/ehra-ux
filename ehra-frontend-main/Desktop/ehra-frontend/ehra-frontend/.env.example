# Copy this file to .env (local dev) or set these as environment variables
# in your Render Static Site's "Environment" tab (production build).

# Base URL the app calls for API requests.
# - Local dev: leave unset — requests to /api are proxied to
#   http://localhost:8080 by vite.config.js.
# - Render / production: set to your deployed backend's URL, e.g.
#   VITE_API_BASE_URL=https://ehra-backend.onrender.com/api
VITE_API_BASE_URL=

# Firebase Web SDK config (Phone Authentication). Safe to expose in the
# client bundle — see src/firebase.js for why.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
